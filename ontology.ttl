@prefix : <http://www.uoc.edu/francisco/eudamed#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.uoc.edu/francisco/eudamed#> .

<http://www.uoc.edu/francisco/eudamed> rdf:type owl:Ontology ;
                                        <http://purl.org/dc/terms/created> "2026-04-27" ;
                                        <http://purl.org/dc/terms/creator> "Francisco" ;
                                        <http://purl.org/dc/terms/description> "Ontology modelling the European catalogue of high-risk medical devices and in-vitro diagnostics under MDR and IVDR regulatory frameworks." ;
                                        <http://purl.org/dc/terms/language> "en" ;
                                        <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                        <http://purl.org/dc/terms/title> "EUDAMED Medical Device Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/language
<http://purl.org/dc/terms/language> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.uoc.edu/francisco/eudamed#affectsRisk
:affectsRisk rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :Device ;
             rdfs:comment "Relates a risk to the type of device it typically affects." ;
             rdfs:label "affects risk" .


###  http://www.uoc.edu/francisco/eudamed#hasCorrectiveAction
:hasCorrectiveAction rdf:type owl:ObjectProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range :CorrectiveAction ;
                     rdfs:comment "Relates an incident to its associated field safety corrective action." ;
                     rdfs:label "has corrective action" .


###  http://www.uoc.edu/francisco/eudamed#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Relates an incident to the identified risk that caused it." ;
         rdfs:label "has risk" .


###  http://www.uoc.edu/francisco/eudamed#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relates a medical device to its assigned risk class under MDR or IVDR." ;
              rdfs:label "has risk class" .


###  http://www.uoc.edu/francisco/eudamed#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:comment "Relates a serious incident to the medical device involved." ;
                rdfs:label "involves device" .


###  http://www.uoc.edu/francisco/eudamed#manufacturedBy
:manufacturedBy rdf:type owl:ObjectProperty ;
                rdfs:domain :Device ;
                rdfs:range :Manufacturer ;
                rdfs:comment "Relates a medical device to its manufacturer." ;
                rdfs:label "manufactured by" .


###  http://www.uoc.edu/francisco/eudamed#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates an incident to the manufacturer that reported it to EUDAMED." ;
            rdfs:label "reported by" .


###  http://www.uoc.edu/francisco/eudamed#triggeredBy
:triggeredBy rdf:type owl:ObjectProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range :Incident ;
             rdfs:comment "Relates a corrective action to the incident that triggered it." ;
             rdfs:label "triggered by" .


#################################################################
#    Data properties
#################################################################

###  http://www.uoc.edu/francisco/eudamed#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :CorrectiveAction ;
            rdfs:range xsd:date ;
            rdfs:comment "Date on which the corrective action was initiated." ;
            rdfs:label "action date" .


###  http://www.uoc.edu/francisco/eudamed#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Official authorization number granted by the competent authority." ;
                     rdfs:label "authorization number" .


###  http://www.uoc.edu/francisco/eudamed#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Regulatory contact email of the manufacturer." ;
              rdfs:label "contact email" .


###  http://www.uoc.edu/francisco/eudamed#country
:country rdf:type owl:DatatypeProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range xsd:string ;
         rdfs:comment "Country where the manufacturer is registered." ;
         rdfs:label "country" .


###  http://www.uoc.edu/francisco/eudamed#countryReported
:countryReported rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Country in which the incident was reported." ;
                 rdfs:label "country reported" .


###  http://www.uoc.edu/francisco/eudamed#deviceId
:deviceId rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          rdfs:comment "Unique identifier of the medical device in EUDAMED." ;
          rdfs:label "device ID" .


###  http://www.uoc.edu/francisco/eudamed#deviceName
:deviceName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "Commercial name of the medical device." ;
            rdfs:label "device name" .


###  http://www.uoc.edu/francisco/eudamed#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Number of devices affected by the corrective action." ;
                 rdfs:label "devices affected" .


###  http://www.uoc.edu/francisco/eudamed#eudamedFscaRef
:eudamedFscaRef rdf:type owl:DatatypeProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:string ;
                rdfs:comment "Official EUDAMED reference number for the corrective action." ;
                rdfs:label "EUDAMED FSCA reference" .


###  http://www.uoc.edu/francisco/eudamed#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Official EUDAMED reference number for the incident." ;
                    rdfs:label "EUDAMED incident reference" .


###  http://www.uoc.edu/francisco/eudamed#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "Single Registration Number assigned to the manufacturer in EUDAMED." ;
            rdfs:label "EUDAMED SRN" .


###  http://www.uoc.edu/francisco/eudamed#fscaId
:fscaId rdf:type owl:DatatypeProperty ;
        rdfs:domain :CorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "Unique identifier of the field safety corrective action." ;
        rdfs:label "FSCA ID" .


###  http://www.uoc.edu/francisco/eudamed#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "International Medical Device Regulators Forum code identifying the risk." ;
           rdfs:label "IMDRF code" .


###  http://www.uoc.edu/francisco/eudamed#incidentId
:incidentId rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Unique identifier of the incident in EUDAMED." ;
            rdfs:label "incident ID" .


###  http://www.uoc.edu/francisco/eudamed#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The use for which the device is intended according to the manufacturer." ;
                 rdfs:label "intended purpose" .


###  http://www.uoc.edu/francisco/eudamed#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device operation depends on an external energy source." ;
          rdfs:label "is active" .


###  http://www.uoc.edu/francisco/eudamed#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device." ;
       rdfs:label "is IVD" .


###  http://www.uoc.edu/francisco/eudamed#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is intended to be implanted in the human body." ;
               rdfs:label "is implantable" .


###  http://www.uoc.edu/francisco/eudamed#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device can be reused after appropriate reprocessing." ;
            rdfs:label "is reusable" .


###  http://www.uoc.edu/francisco/eudamed#manufacturerId
:manufacturerId rdf:type owl:DatatypeProperty ;
                rdfs:domain :Manufacturer ;
                rdfs:range xsd:string ;
                rdfs:comment "Unique identifier of the manufacturer in EUDAMED." ;
                rdfs:label "manufacturer ID" .


###  http://www.uoc.edu/francisco/eudamed#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Legal name of the manufacturer." ;
                  rdfs:label "manufacturer name" .


###  http://www.uoc.edu/francisco/eudamed#outcome
:outcome rdf:type owl:DatatypeProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "Clinical outcome of the incident for the patient." ;
         rdfs:label "outcome" .


###  http://www.uoc.edu/francisco/eudamed#patientAge
:patientAge rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:integer ;
            rdfs:comment "Age of the patient involved in the incident." ;
            rdfs:label "patient age" .


###  http://www.uoc.edu/francisco/eudamed#patientSex
:patientSex rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Sex of the patient involved in the incident." ;
            rdfs:label "patient sex" .


###  http://www.uoc.edu/francisco/eudamed#probability
:probability rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Estimated probability of the risk occurring: Low, Medium or High." ;
             rdfs:label "probability" .


###  http://www.uoc.edu/francisco/eudamed#regulatoryFramework
:regulatoryFramework rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Device ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The regulatory framework applicable to the device: MDR or IVDR." ;
                     rdfs:label "regulatory framework" .


###  http://www.uoc.edu/francisco/eudamed#reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "Date on which the incident was reported to the competent authority." ;
            rdfs:label "report date" .


###  http://www.uoc.edu/francisco/eudamed#riskId
:riskId rdf:type owl:DatatypeProperty ;
        rdfs:domain :Risk ;
        rdfs:range xsd:string ;
        rdfs:comment "Unique identifier of the risk." ;
        rdfs:label "risk ID" .


###  http://www.uoc.edu/francisco/eudamed#riskName
:riskName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "Descriptive name of the identified risk." ;
          rdfs:label "risk name" .


###  http://www.uoc.edu/francisco/eudamed#severity
:severity rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "Severity level of the risk: Critical, Serious, Moderate or Minor." ;
          rdfs:label "severity" .


###  http://www.uoc.edu/francisco/eudamed#status
:status rdf:type owl:DatatypeProperty ;
        rdfs:domain :CorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "Current status of the corrective action: Open or Closed." ;
        rdfs:label "status" .


###  http://www.uoc.edu/francisco/eudamed#udiDI
:udiDI rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "Unique Device Identifier - Device Identifier assigned to the device." ;
       rdfs:label "UDI-DI" .


#################################################################
#    Classes
#################################################################

###  http://www.uoc.edu/francisco/eudamed#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :Device ;
              rdfs:comment "A medical device whose operation depends on a source of energy other than that generated by the human body." ;
              rdfs:label "Active Device" .


###  http://www.uoc.edu/francisco/eudamed#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :ActiveDevice ,
                               :ImplantableDevice ;
               rdfs:comment "A medical device that is both active and implantable, such as a pacemaker or cochlear implant." ;
               rdfs:label "Active Implant" .


###  http://www.uoc.edu/francisco/eudamed#ClassA
:ClassA rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        rdfs:comment "Lowest risk class under IVDR for in vitro diagnostic devices." ;
        rdfs:label "Class A" .


###  http://www.uoc.edu/francisco/eudamed#ClassB
:ClassB rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        rdfs:comment "Low-medium risk class under IVDR for in vitro diagnostic devices." ;
        rdfs:label "Class B" .


###  http://www.uoc.edu/francisco/eudamed#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        rdfs:comment "Medium-high risk class under IVDR for in vitro diagnostic devices." ;
        rdfs:label "Class C" .


###  http://www.uoc.edu/francisco/eudamed#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        rdfs:comment "Highest risk class under IVDR. Devices with the highest individual and public health risk." ;
        rdfs:label "Class D" .


###  http://www.uoc.edu/francisco/eudamed#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        rdfs:comment "Lowest risk class under MDR. Devices with minimal potential for harm." ;
        rdfs:label "Class I" .


###  http://www.uoc.edu/francisco/eudamed#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          rdfs:comment "Highest risk class under MDR. Devices that are life-supporting or life-sustaining." ;
          rdfs:label "Class III" .


###  http://www.uoc.edu/francisco/eudamed#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          rdfs:comment "Medium-low risk class under MDR. Devices with moderate potential for harm." ;
          rdfs:label "Class IIa" .


###  http://www.uoc.edu/francisco/eudamed#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          rdfs:comment "Medium-high risk class under MDR. Devices with significant potential for harm." ;
          rdfs:label "Class IIb" .


###  http://www.uoc.edu/francisco/eudamed#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :triggeredBy ;
                                    owl:minCardinality "1"^^xsd:nonNegativeInteger
                                  ] ;
                  rdfs:comment "A Field Safety Corrective Action (FSCA) taken by a manufacturer in response to a serious incident." ;
                  rdfs:label "Corrective Action" .


###  http://www.uoc.edu/francisco/eudamed#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRiskClass ;
                          owl:minCardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        rdfs:comment "A medical device registered in the EUDAMED catalogue under MDR or IVDR regulatory framework." ;
        rdfs:label "Device" .


###  http://www.uoc.edu/francisco/eudamed#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :ActiveDevice ,
                                         :ImplantableDevice ;
                         rdfs:comment "An active device designed to be implanted in the human body, such as a ventricular assist device." ;
                         rdfs:label "Implantable Active Device" .


###  http://www.uoc.edu/francisco/eudamed#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :Device .


###  http://www.uoc.edu/francisco/eudamed#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction ;
                  rdfs:comment "A corrective action applied to a device while it remains in its current location, including software updates or protocol changes." ;
                  rdfs:label "In Situ Correction" .


###  http://www.uoc.edu/francisco/eudamed#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device .


###  http://www.uoc.edu/francisco/eudamed#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :involvesDevice ;
                            owl:minCardinality "1"^^xsd:nonNegativeInteger
                          ] ;
          rdfs:comment "A serious incident or near-incident involving a medical device notified to EUDAMED." ;
          rdfs:label "Incident" .


###  http://www.uoc.edu/francisco/eudamed#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "A risk that may cause direct patient harm or injury." ;
            rdfs:label "Injury Risk" .


###  http://www.uoc.edu/francisco/eudamed#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "A risk related to device malfunction or failure to perform as intended." ;
                 rdfs:label "Malfunction Risk" .


###  http://www.uoc.edu/francisco/eudamed#Manufacturer
:Manufacturer rdf:type owl:Class .


###  http://www.uoc.edu/francisco/eudamed#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "A corrective action involving the retrieval or replacement of a distributed medical device." ;
        rdfs:label "Recall" .


###  http://www.uoc.edu/francisco/eudamed#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "A potential hazard identified for a medical device according to IMDRF nomenclature." ;
      rdfs:label "Risk" .


###  http://www.uoc.edu/francisco/eudamed#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "The risk classification assigned to a medical device based on its intended purpose and associated risks." ;
           rdfs:label "Risk Class" .


###  http://www.uoc.edu/francisco/eudamed#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :CorrectiveAction ;
             rdfs:comment "A safety communication issued to healthcare professionals regarding device risks and updated usage instructions." ;
             rdfs:label "Safety Alert" .


###  http://www.uoc.edu/francisco/eudamed#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "An incident that directly or indirectly led to patient death, serious deterioration of health, or serious public health threat." ;
                 rdfs:label "Serious Incident" .


#################################################################
#    Individuals
#################################################################

###  http://dbpedia.org/resource/Abbott_Laboratories
<http://dbpedia.org/resource/Abbott_Laboratories> rdf:type owl:NamedIndividual ;
                                                  owl:sameAs :MAN_002 .


###  http://www.uoc.edu/francisco/eudamed#MAN_002
:MAN_002 rdf:type owl:NamedIndividual .


###  http://dbpedia.org/resource/In_vitro_diagnostics
<http://dbpedia.org/resource/In_vitro_diagnostics> rdf:type owl:NamedIndividual ;
                                                   owl:sameAs :InVitroDiagnosticDevice .


###  http://www.uoc.edu/francisco/eudamed#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:NamedIndividual .


###  http://dbpedia.org/resource/Medical_device_manufacturer
<http://dbpedia.org/resource/Medical_device_manufacturer> rdf:type owl:NamedIndividual ;
                                                          owl:sameAs :Manufacturer .


###  http://www.uoc.edu/francisco/eudamed#Manufacturer
:Manufacturer rdf:type owl:NamedIndividual .


###  http://dbpedia.org/resource/Medtronic
<http://dbpedia.org/resource/Medtronic> rdf:type owl:NamedIndividual ;
                                        owl:sameAs :MAN_001 .


###  http://www.uoc.edu/francisco/eudamed#MAN_001
:MAN_001 rdf:type owl:NamedIndividual .


###  http://dbpedia.org/resource/Siemens_Healthineers
<http://dbpedia.org/resource/Siemens_Healthineers> rdf:type owl:NamedIndividual ;
                                                   owl:sameAs :MAN_003 .


###  http://www.uoc.edu/francisco/eudamed#MAN_003
:MAN_003 rdf:type owl:NamedIndividual .


###  http://dbpedia.org/resource/Implant_(medicine)
<http://dbpedia.org/resource/Implant_(medicine)> rdf:type owl:NamedIndividual ;
                                                 owl:sameAs :ImplantableDevice .


###  http://www.uoc.edu/francisco/eudamed#ImplantableDevice
:ImplantableDevice rdf:type owl:NamedIndividual .


###  http://www.uoc.edu/francisco/eudamed#ClassC_instance
:ClassC_instance rdf:type owl:NamedIndividual ,
                          :ClassC ;
                 rdfs:comment "Medium-high risk class under IVDR regulation for in vitro diagnostics." ;
                 rdfs:label "Class C IVDR" .


###  http://www.uoc.edu/francisco/eudamed#ClassIII_instance
:ClassIII_instance rdf:type owl:NamedIndividual ,
                            :ClassIII ;
                   rdfs:comment "Highest risk class under MDR regulation for medical devices." ;
                   rdfs:label "Class III MDR" .


###  http://www.uoc.edu/francisco/eudamed#ClassIIb_instance
:ClassIIb_instance rdf:type owl:NamedIndividual ,
                            :ClassIIb ;
                   rdfs:comment "Medium-high risk class under MDR regulation." ;
                   rdfs:label "Class IIb MDR" .


###  http://www.uoc.edu/francisco/eudamed#DEV_001
:DEV_001 rdf:type owl:NamedIndividual ,
                  :ImplantableActiveDevice ;
         :hasRiskClass :ClassIII_instance ;
         :manufacturedBy :MAN_001 ;
         :deviceId "DEV-001" ;
         :deviceName "HeartMate 3 LVAD" ;
         :intendedPurpose "Ventricular assist device for end-stage heart failure" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "false"^^xsd:boolean ;
         :isImplantable "true"^^xsd:boolean ;
         :isReusable "false"^^xsd:boolean ;
         :regulatoryFramework "MDR" ;
         :udiDI "(01)00380740009095" ;
         rdfs:comment "Left ventricular assist device for end-stage heart failure patients." ;
         rdfs:label "HeartMate 3 LVAD" .


###  http://www.uoc.edu/francisco/eudamed#DEV_002
:DEV_002 rdf:type owl:NamedIndividual ,
                  :ActiveImplant ;
         :hasRiskClass :ClassIII_instance ;
         :manufacturedBy :MAN_001 ;
         :deviceId "DEV-002" ;
         :deviceName "Micra AV Transcatheter Pacing System" ;
