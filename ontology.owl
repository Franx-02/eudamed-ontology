    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/francisco/eudamed##ActiveDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:comment>A medical device whose operation depends on a source of energy other than that generated by the human body.</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ActiveImplant -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##ImplantableDevice"/>
        <rdfs:comment>A medical device that is both active and implantable, such as a pacemaker or cochlear implant.</rdfs:comment>
        <rdfs:label>Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassA -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassA">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Lowest risk class under IVDR for in vitro diagnostic devices.</rdfs:comment>
        <rdfs:label>Class A</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassB -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassB">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Low-medium risk class under IVDR for in vitro diagnostic devices.</rdfs:comment>
        <rdfs:label>Class B</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassC -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassC">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Medium-high risk class under IVDR for in vitro diagnostic devices.</rdfs:comment>
        <rdfs:label>Class C</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassD -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassD">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Highest risk class under IVDR. Devices with the highest individual and public health risk.</rdfs:comment>
        <rdfs:label>Class D</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassI -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassI">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Lowest risk class under MDR. Devices with minimal potential for harm.</rdfs:comment>
        <rdfs:label>Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassIII -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Highest risk class under MDR. Devices that are life-supporting or life-sustaining.</rdfs:comment>
        <rdfs:label>Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassIIa -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Medium-low risk class under MDR. Devices with moderate potential for harm.</rdfs:comment>
        <rdfs:label>Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ClassIIb -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Medium-high risk class under MDR. Devices with significant potential for harm.</rdfs:comment>
        <rdfs:label>Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##CorrectiveAction -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##CorrectiveAction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/francisco/eudamed##triggeredBy"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A Field Safety Corrective Action (FSCA) taken by a manufacturer in response to a serious incident.</rdfs:comment>
        <rdfs:label>Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##Device -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##Device">
        <rdfs:subClassOf>
