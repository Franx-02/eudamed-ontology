    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/francisco/eudamed##actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##actionDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label>action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##authorizationNumber">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Official authorization number granted by the competent authority.</rdfs:comment>
        <rdfs:label>authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##contactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##contactEmail">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Regulatory contact email of the manufacturer.</rdfs:comment>
        <rdfs:label>contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##country -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##country">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Country where the manufacturer is registered.</rdfs:comment>
        <rdfs:label>country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##countryReported -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##countryReported">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Country in which the incident was reported.</rdfs:comment>
        <rdfs:label>country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##deviceId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##deviceId">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the medical device in EUDAMED.</rdfs:comment>
        <rdfs:label>device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##deviceName">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Commercial name of the medical device.</rdfs:comment>
        <rdfs:label>device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##devicesAffected">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Number of devices affected by the corrective action.</rdfs:comment>
        <rdfs:label>devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##eudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##eudamedFscaRef">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Official EUDAMED reference number for the corrective action.</rdfs:comment>
        <rdfs:label>EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##eudamedIncidentRef">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Official EUDAMED reference number for the incident.</rdfs:comment>
        <rdfs:label>EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##eudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##eudamedSRN">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Single Registration Number assigned to the manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label>EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##fscaId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##fscaId">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the field safety corrective action.</rdfs:comment>
        <rdfs:label>FSCA ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##imdrfCode">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>International Medical Device Regulators Forum code identifying the risk.</rdfs:comment>
        <rdfs:label>IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##incidentId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##incidentId">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the incident in EUDAMED.</rdfs:comment>
        <rdfs:label>incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##intendedPurpose">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The use for which the device is intended according to the manufacturer.</rdfs:comment>
        <rdfs:label>intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##isActive -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##isActive">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device operation depends on an external energy source.</rdfs:comment>
        <rdfs:label>is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##isIVD">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is an in vitro diagnostic device.</rdfs:comment>
        <rdfs:label>is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##isImplantable">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is intended to be implanted in the human body.</rdfs:comment>
        <rdfs:label>is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##isReusable">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device can be reused after appropriate reprocessing.</rdfs:comment>
        <rdfs:label>is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##manufacturerId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##manufacturerId">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label>manufacturer ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##manufacturerName -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##manufacturerName">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Legal name of the manufacturer.</rdfs:comment>
        <rdfs:label>manufacturer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##outcome -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##outcome">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Clinical outcome of the incident for the patient.</rdfs:comment>
        <rdfs:label>outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##patientAge -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##patientAge">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label>patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##patientSex -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##patientSex">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label>patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##probability -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##probability">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Estimated probability of the risk occurring: Low, Medium or High.</rdfs:comment>
        <rdfs:label>probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##regulatoryFramework -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##regulatoryFramework">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The regulatory framework applicable to the device: MDR or IVDR.</rdfs:comment>
        <rdfs:label>regulatory framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##reportDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the incident was reported to the competent authority.</rdfs:comment>
        <rdfs:label>report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##riskId -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##riskId">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the risk.</rdfs:comment>
        <rdfs:label>risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##riskName -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##riskName">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Descriptive name of the identified risk.</rdfs:comment>
        <rdfs:label>risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##severity -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##severity">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Severity level of the risk: Critical, Serious, Moderate or Minor.</rdfs:comment>
        <rdfs:label>severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##status -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##status">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current status of the corrective action: Open or Closed.</rdfs:comment>
        <rdfs:label>status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##udiDI -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/francisco/eudamed##udiDI">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique Device Identifier - Device Identifier assigned to the device.</rdfs:comment>
        <rdfs:label>UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
