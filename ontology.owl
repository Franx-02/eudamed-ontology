<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/francisco/eudamed#"
     xml:base="http://www.uoc.edu/francisco/eudamed"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:eudamed="http://www.uoc.edu/francisco/eudamed##">
    <owl:Ontology rdf:about="http://www.uoc.edu/francisco/eudamed">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</terms:created>
        <terms:creator>Francisco</terms:creator>
        <terms:description>Ontology modelling the European catalogue of high-risk medical devices and in-vitro diagnostics under MDR and IVDR regulatory frameworks.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title>EUDAMED Medical Device Ontology</terms:title>
        <rdfs:comment>Ontology modelling the European catalogue of high-risk medical devices and in-vitro diagnostics under MDR and IVDR regulatory frameworks.</rdfs:comment>
        <rdfs:label>EUDAMED Medical Device Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/francisco/eudamed##affectsRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##affectsRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:comment>Relates a risk to the type of device it typically affects.</rdfs:comment>
        <rdfs:label>affects risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:comment>Relates an incident to its associated field safety corrective action.</rdfs:comment>
        <rdfs:label>has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##hasRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##Risk"/>
        <rdfs:comment>Relates an incident to the identified risk that caused it.</rdfs:comment>
        <rdfs:label>has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##hasRiskClass">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##RiskClass"/>
        <rdfs:comment>Relates a medical device to its assigned risk class under MDR or IVDR.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##involvesDevice">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:comment>Relates a serious incident to the medical device involved.</rdfs:comment>
        <rdfs:label>involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##manufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##manufacturedBy">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:comment>Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label>manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##reportedBy">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##Manufacturer"/>
        <rdfs:comment>Relates an incident to the manufacturer that reported it to EUDAMED.</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/francisco/eudamed##triggeredBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/francisco/eudamed##triggeredBy">
        <rdfs:domain rdf:resource="http://www.uoc.edu/francisco/eudamed##CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/francisco/eudamed##Incident"/>
        <rdfs:comment>Relates a corrective action to the incident that triggered it.</rdfs:comment>
        <rdfs:label>triggered by</rdfs:label>
    </owl:ObjectProperty>
    


