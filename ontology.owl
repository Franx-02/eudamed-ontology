                <owl:onProperty rdf:resource="http://www.uoc.edu/francisco/eudamed##hasRiskClass"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A medical device registered in the EUDAMED catalogue under MDR or IVDR regulatory framework.</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/francisco/eudamed##ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/francisco/eudamed##ImplantableActiveDevice">
